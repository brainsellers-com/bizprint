{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell",
  "permissions": {
    "allow": [
      "Skill(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "PowerShell(cd *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(file *)",
      "PowerShell(wc *)",
      "PowerShell(which *)",
      "PowerShell(git *)",
      "PowerShell(mvn clean*)",
      "PowerShell(mvn test*)",
      "PowerShell(mvn package*)",
      "PowerShell(mvn verify*)",
      "PowerShell(mvn compile*)",
      "PowerShell(mvn install*)",
      "PowerShell(mvn checkstyle:*)",
      "PowerShell(mvn editorconfig:*)",
      "PowerShell(tasklist*)",
      "PowerShell(gh issue list*)",
      "PowerShell(gh issue view*)",
      "PowerShell(gh issue create*)",
      "PowerShell(gh issue close*)",
      "PowerShell(gh pr list*)",
      "PowerShell(gh pr view*)",
      "PowerShell(gh pr create*)",
      "PowerShell(gh pr diff*)",
      "PowerShell(gh pr comment*)",
      "PowerShell(gh pr merge*)",
      "PowerShell(gh pr review*)",
      "PowerShell(gh pr checks*)",
      "PowerShell(gh run *)",
      "PowerShell(gh api*)"
    ],
    "deny": [
      "Bash",
      "PowerShell(mvn deploy*)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Edit(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Edit(~/.aws/**)",
      "Read(~/.azure/**)",
      "Edit(~/.azure/**)",
      "Read(~/.kube/**)",
      "Edit(~/.kube/**)",
      "Read(~/.npmrc)",
      "Edit(~/.npmrc)",
      "Read(~/.git-credentials)",
      "Edit(~/.git-credentials)",
      "Read(~/.config/gh/**)",
      "Edit(~/.config/gh/**)",
      "Read(~/.bashrc)",
      "Edit(~/.bashrc)",
      "Read(~/.zshrc)",
      "Edit(~/.zshrc)",
      "Read(*.env)",
      "Edit(*.env)",
      "Read(.env)",
      "Edit(.env)",
      "Read(.env.*)",
      "Edit(.env.*)"
    ]
  },
  "extraKnownMarketplaces": {
    "brainsellers-com": {
      "source": {
        "source": "github",
        "repo": "brainsellers-com/bs-cc-plugins"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "bs-cc-plugins@brainsellers-com": true
  }
}
